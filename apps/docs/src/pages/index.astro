---
import { appDocsContent } from "../content/app-docs.generated";
import DocsLayout from "../layouts/DocsLayout.astro";

const repoUrl = "https://github.com/davidjpramsay/hearth";
const markdownUrl = `${repoUrl}/blob/main/docs/APP_DOCS.md`;
const sections = appDocsContent.sections ?? [];
const title = "Hearth Docs";
---

<DocsLayout title={title} description={appDocsContent.hero.summary}>
  <main class="shell">
    <header class="hero">
      <div class="hero-copy">
        <p class="eyebrow">{appDocsContent.hero.eyebrow}</p>
        <h1>{title}</h1>
        <p class="headline">{appDocsContent.hero.headline}</p>
        <p class="summary">{appDocsContent.hero.summary}</p>
        <div class="hero-actions">
          <a href="#install" class="button button-primary">Start here</a>
          <a href={repoUrl} class="button button-secondary">GitHub repo</a>
          <a href={markdownUrl} class="button button-secondary">Markdown mirror</a>
        </div>
      </div>

      <aside class="highlights">
        <p class="highlights-label">Highlights</p>
        <ul>
          {appDocsContent.hero.highlights.map((highlight) => (
            <li>{highlight}</li>
          ))}
        </ul>
      </aside>
    </header>

    <div class="content-grid">
      <nav class="sidebar" aria-label="Docs sections">
        <p class="sidebar-label">Contents</p>
        <ul>
          {sections.map((section) => (
            <li>
              <a href={`#${section.id}`}>{section.title}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="sections">
        {sections.map((section) => (
          <section id={section.id} class="section-card">
            <p class="section-eyebrow">{section.eyebrow}</p>
            <h2>{section.title}</h2>
            <p class="section-summary">{section.summary}</p>

            <div class="prose">
              {section.body.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>

            {section.bullets?.length ? (
              <ul class="bullet-list">
                {section.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            ) : null}

            {section.code ? (
              <div class="code-block">
                <div class="code-header">
                  <span>{section.code.title}</span>
                  <span>{section.code.language}</span>
                </div>
                <pre><code>{section.code.content}</code></pre>
              </div>
            ) : null}
          </section>
        ))}
      </div>
    </div>
  </main>
</DocsLayout>
