# Hearth example env
#
# Copy this file to `.env` for native Node or generic Docker deployments.

APP_NAME=Hearth
HOST=0.0.0.0
PORT=3000

# Optional container image override for image-based Docker deployments.
HEARTH_IMAGE=ghcr.io/davidjpramsay/hearth:latest

# For local/native deployments you can keep data under the project folder.
# For Docker deployments, leave DATA_DIR as /app/data inside the container.
DATA_DIR=./data
BACKUP_DIR=./data/backups

# Required on the first startup until Hearth has initialized the stored
# admin password hash in the database.
ADMIN_PASSWORD=change-me

# Optional: only needed for live Bible Verse module data.
ESV_API_KEY=

# Optional backup tuning.
BACKUP_INTERVAL_MINUTES=360
BACKUP_RETENTION_DAYS=30

# Optional. Only needed if you are serving the admin/web app from a different origin.
# CORS_ORIGINS=
