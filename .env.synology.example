# Hearth Synology example env
#
# Copy or rename this file to `.env` in the same folder as
# `docker-compose.synology.yml` before creating the project in
# Synology Container Manager.

APP_NAME=Hearth

# Optional container image override. Leave this on `latest` for normal installs,
# or pin to a release tag such as `ghcr.io/davidjpramsay/hearth:v0.1.0`.
HEARTH_IMAGE=ghcr.io/davidjpramsay/hearth:latest

# Required on the first startup until Hearth has initialized the stored
# admin password hash in /app/data/hearth.db.
ADMIN_PASSWORD=change-me

# Optional: only needed for live Bible Verse module data.
ESV_API_KEY=

# Optional: only needed for the Kobo Reader module.
KOBO_READER_APP_DB_PATH=/external/calibreweb/app.db
KOBO_READER_LIBRARY_DB_PATH=/external/books/metadata.db
KOBO_READER_LIBRARY_ROOT=/external/books

# Optional backup tuning.
BACKUP_INTERVAL_MINUTES=360
BACKUP_RETENTION_DAYS=30
